@startuml
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam actorStyle awesome
skinparam linetype ortho

actor Gost
actor "Email servis" as EMAIL

rectangle "Javna cona sistema Maestro" {

  together {
    usecase "Pregled osnovne strani" as UC_HOME
    usecase "Pregled nagradnega programa" as UC_REWARDS
    usecase "Pregled FAQ" as UC_FAQ
    usecase "Pregled GDPR" as UC_GDPR
    usecase "Pregled pogojev uporabe" as UC_TERMS
    usecase "Pregled kontaktnih informacij" as UC_CONTACT_INFO
    usecase "Kontaktiranje podpore" as UC_CONTACT
  }

  together {
    usecase "Registracija stranke" as UC_REGISTER
    usecase "Prijava" as UC_LOGIN
    usecase "Pozabljeno geslo" as UC_FORGOT
    usecase "Ponastavitev gesla" as UC_RESET
    usecase "Potrditev računa" as UC_VERIFY
  }

  together {
    usecase "Validacija JWT" as UC_JWT
    usecase "Validacija vhodnih podatkov" as UC_VALIDATION
    usecase "Pošiljanje potrditvenega emaila" as UC_SEND_VERIFY
    usecase "Pošiljanje emaila za reset gesla" as UC_SEND_RESET
  }

}

Gost --> UC_HOME
Gost --> UC_REWARDS
Gost --> UC_FAQ
Gost --> UC_GDPR
Gost --> UC_TERMS
Gost --> UC_CONTACT_INFO
Gost --> UC_CONTACT

Gost --> UC_REGISTER
Gost --> UC_LOGIN
Gost --> UC_FORGOT

EMAIL --> UC_SEND_VERIFY
EMAIL --> UC_SEND_RESET

UC_REGISTER .> UC_SEND_VERIFY : <<include>>
UC_FORGOT .> UC_SEND_RESET : <<include>>

UC_LOGIN .> UC_JWT : <<include>>
UC_REGISTER .> UC_VALIDATION : <<include>>

@enduml